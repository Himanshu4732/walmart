# HarvestIQ Environment Configuration
# Copy this file to .env and update the values

# Backend Configuration
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
DATABASE_URL=sqlite:///./harvestiq.db

# For production with PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/harvestiq

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8000
FRONTEND_API_BASE=http://localhost:5173

# Development Settings
DEBUG=true
LOG_LEVEL=info

# AI/ML Configuration (for future integration)
# OPENAI_API_KEY=your-openai-api-key
# HUGGINGFACE_API_KEY=your-huggingface-api-key
# ML_MODEL_PATH=/path/to/your/model.onnx

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,bmp,tiff

# Email Configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Redis Configuration (for caching, optional)
# REDIS_URL=redis://localhost:6379/0

# Monitoring and Analytics
# SENTRY_DSN=your-sentry-dsn
# GOOGLE_ANALYTICS_ID=your-ga-id
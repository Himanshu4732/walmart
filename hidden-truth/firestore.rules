rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function authed() { 
      return request.auth != null; 
    }

    match /rooms/{roomId} {
      allow read: if authed();
      allow create, update, delete: if request.auth.token.admin == true;

      match /players/{playerId} {
        allow read: if authed();
        allow create: if authed() && request.auth.uid == request.resource.data.uid;
        allow update: if authed() && request.auth.uid == playerId
          && request.resource.data.keys().hasOnly([
            'uid','displayName','photoURL','isReady','isConnected','lastSeen','joinedAt','role'
          ])
          && (
            // role can only be set from null -> 'truth'|'impostor' by admin; clients can't change it
            (request.resource.data.role == resource.data.role) || (request.auth.token.admin == true)
          );
        allow delete: if authed() && request.auth.uid == playerId;
      }

      match /state/{docId} {
        allow read: if authed();
        allow write: if request.auth.token.admin == true;
      }

      match /clues/{uid} {
        allow read: if authed();
        allow create: if authed() && request.auth.uid == uid;
        allow update, delete: if false;
      }

      match /votes/{uid} {
        allow read: if authed();
        allow create: if authed() && request.auth.uid == uid;
        allow update, delete: if false;
      }

      // secrets path is admin-only (server)
      match /secrets/{docId} {
        allow read, write: if request.auth.token.admin == true;
      }
    }
  }
}
